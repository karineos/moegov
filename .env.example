# Microsoft Foundry Agent settings
# Example format: https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT
FOUNDRY_PROJECT_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT
FOUNDRY_AGENT_NAME=YOUR-AGENT-NAME
# Optional if you want a specific published/versioned agent version
# FOUNDRY_AGENT_VERSION=1

# Optional app settings
APP_TITLE=MOEgov
PORT=8080

# Local dev only: if DefaultAzureCredential is not available, sign in with Azure CLI: az login
# The app uses DefaultAzureCredential / Managed Identity in Azure App Service.
